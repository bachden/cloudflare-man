NODE_ENV=development
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
# Vite dev server (apps/web). Not used in production, where the API serves the built frontend.
WEB_HOST=127.0.0.1
WEB_PORT=5173
# Optional. Must be reachable from every store running the installer.
# Defaults to http://SERVER_HOST:SERVER_PORT when unset; override for production.
PUBLIC_BASE_URL=https://cloudflare-man.example.com
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cloudflare_man
DATABASE_SCHEMA=public
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARACTERS
SESSION_TTL_HOURS=12
CLOUDFLARED_VERSION=2026.7.2
ALLOW_MOCK_ACCOUNTS=false
